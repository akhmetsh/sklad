# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/warehouse_db?schema=public"

# Auth.js secret - generate with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here"

# NEXTAUTH_URL — only needed in production. In dev, Auth.js v5 auto-detects
# from request headers, so this can be left commented out.
# NEXTAUTH_URL="https://sklad.yourcompany.kz"
